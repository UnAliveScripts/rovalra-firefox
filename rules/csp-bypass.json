[
  {
    "id": 1,
    "priority": 1,
    "condition": {
      "urlFilter": "||roblox.com",
      "resourceTypes": [
        "main_frame",
        "sub_frame",
        "stylesheet",
        "script",
        "image",
        "font",
        "media",
        "xmlhttprequest",
        "other"
      ]
    },
    "action": {
      "type": "modifyHeaders",
      "responseHeaders": [
        { "header": "content-security-policy", "operation": "remove" },
        { "header": "content-security-policy-report-only", "operation": "remove" },
        { "header": "x-content-security-policy", "operation": "remove" }
      ]
    }
  }
]
